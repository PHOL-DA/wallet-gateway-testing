# Default deployment configuration for scripts/deploy.sh
# You can override any value by exporting env vars before running deploy.

NAMESPACE=wallet-stack
TRAEFIK_NAMESPACE=traefik

WALLET_GATEWAY_CHART=oci://ghcr.io/digital-asset/wallet-gateway/helm/wallet-gateway
SPLICE_PORTFOLIO_CHART=oci://ghcr.io/digital-asset/splice-portfolio/helm/splice-portfolio

# Pin chart versions if needed (blank = latest available)
WALLET_GATEWAY_CHART_VERSION=0.17.5
SPLICE_PORTFOLIO_CHART_VERSION=0.18.0

# Image tag defaults used during helm upgrade --install
# These are set explicitly to avoid chart-generated `v` prefix mismatches.
WALLET_GATEWAY_IMAGE_TAG=0.17.5
SPLICE_PORTFOLIO_IMAGE_TAG=0.18.0

# Optional wallet gateway values override file used by scripts/deploy.sh
WALLET_GATEWAY_VALUES_FILE=config/wallet-gateway.values.yaml
